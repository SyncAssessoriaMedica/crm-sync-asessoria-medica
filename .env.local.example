# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Evolution API (WhatsApp) — server-to-server calls from the CRM to Evolution.
# Never expose EVOLUTION_API_KEY in webhook URLs or public logs.
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-api-key

# Webhook security — dedicated secret for INCOMING webhooks from Evolution.
# Recommended: generate with `openssl rand -hex 32`
# The webhook URL registered in Evolution will be:
#   https://your-app.vercel.app/api/webhooks/evolution?token=<EVOLUTION_WEBHOOK_SECRET>
# Required in production. This separates the inbound webhook secret from the
# outbound server-to-server Evolution API key.
EVOLUTION_WEBHOOK_SECRET=your-evolution-webhook-secret

# Shared secret for the /api/webhooks/leads endpoint.
# Required in production — the endpoint returns 503 if this is missing.
# Preferred auth: Header x-webhook-secret: <value>
# Deprecated: ?secret= query param (still accepted, avoid in new integrations).
WEBHOOK_SECRET=your-webhook-secret

# App public URL — used to generate webhook callback URLs in admin actions.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — protects /api/cron/followups from unauthorized invocations.
# Vercel passes this automatically in the Authorization header when running cron jobs.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret
